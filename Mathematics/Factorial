"""
Calculates the factorial of a non-negative integer n.
Factorial of 0 is 1.
e.g., 5! = 5 * 4 * 3 * 2 * 1 = 120.
"""
def calculate_factorial(n):
    fact=1
    if n==0:
        print(1)
    elif n>0:
        for i in range(1,n+1):
            fact*=i
        print(fact)
calculate_factorial(5)
calculate_factorial(0)
calculate_factorial(1)
